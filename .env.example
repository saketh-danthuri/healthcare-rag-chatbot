# ============================================
# Environment Variables - Copy to .env and fill in
# ============================================

# --- Azure AI Foundry (OpenAI) ---
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# --- Azure AI Search ---
AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
AZURE_SEARCH_API_KEY=your-search-admin-key
AZURE_SEARCH_INDEX_NAME=healthcare-runbooks

# --- Azure Blob Storage ---
AZURE_BLOB_CONNECTION_STRING=your-connection-string
AZURE_BLOB_CONTAINER_NAME=documents

# --- PostgreSQL (Demo DB) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=healthcare_ops
POSTGRES_USER=chatbot_readonly
POSTGRES_PASSWORD=changeme_in_production

# --- Email (Gmail SMTP for escalation) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
ESCALATION_DEFAULT_TO=your-email@gmail.com

# --- Azure Entra ID (Authentication) ---
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-backend-client-id
AZURE_CLIENT_SECRET=your-client-secret

# --- Azure Application Insights (Monitoring) ---
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=xxx;IngestionEndpoint=xxx

# --- Document Paths ---
DOCS_BASE_PATH=/app/docs

# --- App Settings ---
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
